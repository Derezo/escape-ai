# Copy to .env and adjust as needed. All values are optional; defaults shown.

# HTTP / Socket.IO listen port
PORT=3000

# Bind address (0.0.0.0 = all interfaces)
HOST=0.0.0.0

# Authoritative tick rate in Hz (snapshots per second)
TICK_RATE=20

# Units per second a player moves at full input magnitude
PLAYER_SPEED=200

# development | production  (production locks down CORS)
NODE_ENV=development

# SQLite file for username-only accounts + persistent per-user stats. A relative
# path is resolved against the server dir; the parent dir is created on boot.
# DB_PATH=./data/escapeai.db

# Seconds the "ESCAPED!" win state is held before the player respawns as a fresh
# animal (the round-based loop: escape -> celebrate -> new run).
# ESCAPE_CELEBRATION_SECS=4
