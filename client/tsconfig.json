{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "useDefineForClassFields": true,

    // `node` is needed for the Node APIs in vite.config.ts (node:url); `vite/client`
    // provides import.meta.env typing for src. The Node globals are harmless in src.
    "types": ["vite/client", "node"],

    "paths": {
      "@shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
