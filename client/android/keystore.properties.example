# Escape AI — release signing config TEMPLATE.
#
# Copy this to `keystore.properties` (same directory) and fill in real values to
# produce a SIGNED release APK/AAB. The real keystore.properties is GITIGNORED —
# it holds passwords and must never be committed. See docs/ANDROID.md.
#
# app/build.gradle reads this file via rootProject.file("keystore.properties").
# If it is absent, the release build still assembles (just unsigned), and debug
# builds are unaffected.
#
# Generate a keystore once (10000-day validity, RSA 2048):
#   keytool -genkeypair -v \
#     -keystore /path/OUTSIDE/the/repo/escape-ai-release.keystore \
#     -alias escape-ai -keyalg RSA -keysize 2048 -validity 10000
#
# CRITICAL: back up the keystore + these passwords somewhere safe and OUTSIDE the
# repo. If you lose them you can never ship an update to an already-installed app.

# Absolute path to the .keystore file (keep it OUTSIDE the repo tree).
storeFile=/home/you/.escape-ai-signing/escape-ai-release.keystore

# The keystore password.
storePassword=CHANGE_ME

# The key alias inside the keystore.
keyAlias=escape-ai

# The key password (often the same as storePassword for a single-key keystore).
keyPassword=CHANGE_ME
