# scripts/deploy.env.example — deploy configuration for Escape AI.
#
# Copy to scripts/deploy.env and adjust. BOTH scripts/provision-escape.sh and
# scripts/deploy-server.sh source this file (if present) so the VPS host, app
# user, domain, and port live in exactly one place — never hard-coded in a
# script. Any value can also be overridden inline:  APP_PORT=4000 ./deploy-server.sh
#
# scripts/deploy.env is gitignored (it names your host) — keep this .example
# committed as the template. Keep your real deploy.env owner-only:
#   cp scripts/deploy.env.example scripts/deploy.env && chmod 600 scripts/deploy.env
# (both deploy scripts also chmod 600 it on every run, so a fresh copy is locked
# down automatically — this is just the manual belt-and-suspenders.)

# --- SSH login used to reach the VPS (a LOGIN user with sudo) — REQUIRED ------
# The deploy connects as this user, then chowns files to APP_USER and runs pm2
# as APP_USER. Any sudo-capable login user works. DEPLOY_USER and DEPLOY_HOST
# have NO default in the scripts — they identify your infrastructure and must be
# set here (the scripts error out if either is missing).
DEPLOY_USER=your-ssh-login-user
DEPLOY_HOST=your-vps-hostname.example.com
# Private key used for the SSH/rsync connection.
SSH_KEY=$HOME/.ssh/id_ed25519

# --- The application identity on the VPS -------------------------------------
# Public hostname the game is served at (nginx server_name + Let's Encrypt cert).
# REQUIRED — no default (it reveals the host); the scripts error if it is unset.
APP_DOMAIN=escape.example.com
# The dedicated, login-disabled (nologin) system user that OWNS the files and
# RUNS the node process under its own pm2 (pm2-escape.service). Created by
# provision-escape.sh. Never a login user — it cannot ssh in.
APP_USER=escape
# Absolute deploy root on the VPS. Owned by APP_USER.
REMOTE_PATH=/var/www/escape
# Loopback port the node server binds; nginx reverse-proxies to it. Bound to
# 127.0.0.1 only and NEVER opened in the firewall — the public edge is nginx on
# 443. Pick a port that is free on your VPS and not the well-known RDP port 3389.
# Confirm it is free before use:
#   ssh <host> 'ss -tlnp | grep :3390'
APP_PORT=3390

# --- Node runtime ------------------------------------------------------------
NODE_ENV=production
# pm2 process name (also the systemd unit suffix: pm2-${APP_USER}.service).
PM2_NAME=escape
