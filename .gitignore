node_modules/
dist/
.env
.DS_Store

# SQLite store for username-only accounts + per-user stats (server/db.js). The
# DB file plus its WAL/SHM sidecars are runtime state, never committed.
server/data/

# Sprite staging: per-frame SVGs emitted by scripts/gen-sprites.js. Regenerable
# from the species builders; only the packed assets/sprites/atlas.{png,json} are
# the committed runtime artifact (a clean clone boots on the atlas, no sharp).
assets/sprites/frames/

# Tile staging: per-tile SVGs emitted by scripts/gen-tiles.js. Regenerable from
# the tile builders; only the packed assets/tiles/tileset.{png,json} are the
# committed runtime artifact (a clean clone boots on the tileset, no sharp).
assets/tiles/svg/

# Audio staging: raw Suno samples + provenance from scripts/generate-{music,sfx}.py.
# Two samples + a <key>.json (request + raw response) per asset; sample #1 is
# auto-copied to the committed assets/{music,sfx}/ target. Regenerable (Suno retains
# files ~15 days), large, and OUTSIDE Vite publicDir so raw never ships in the bundle/APK.
asset-pipeline/output/
# Rolling backups written by change-*-track.py next to the target before a swap.
assets/music/*.bak
assets/sfx/*.bak

# --- Capacitor / Android ---
#
# DECISION (jam scaffold): we ignore the entire generated `client/android/`
# platform folder. It is 100% regenerable from the committed Capacitor config
# with `cd client && npx cap add android && npx cap sync` (see docs/ANDROID.md),
# so there is nothing to lose and a lot of native boilerplate + build noise to
# avoid in the repo. This is the right call for a 72-hour jam where the Android
# build is a nice-to-have wrapper, not the product.
#
# IF you later want to commit the native project (the norm for a real, shipping
# app — so signing config, custom native code, and icons are version-controlled):
# delete the `client/android/` line below. Capacitor already writes a thorough
# `client/android/.gitignore` that excludes the actual build artifacts listed
# here (build/, .gradle/, local.properties, *.apk/*.aab, copied web assets),
# so committing the folder will NOT commit build output.
client/android/

# Build artifacts — kept explicit so they stay ignored even if `android/` is
# committed (these mirror Capacitor's generated android/.gitignore):
android/app/build/
android/build/
android/.gradle/
android/local.properties
android/capacitor-cordova-android-plugins/
*.apk
*.aab
*.keystore
*.jks

# Claude Code session scratch (worktrees, locks) — never commit.
# Ignore the CONTENTS (not the dir itself) so git still descends and the
# negation below can re-include the one tracked subtree.
.claude/*
# …except the project-level subagent definitions: shared tooling that every
# contributor should get on clone, so they are tracked.
!.claude/agents/
