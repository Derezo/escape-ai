node_modules/
dist/
.env
.DS_Store

# Competition submission bundle written by scripts/bundle-submission.sh. A
# generated artifact (the git-tracked sources, zipped) — regenerate, never commit.
*-submission.zip

# Local deploy configuration (names your VPS host/user). Copy from
# scripts/deploy.env.example, which IS committed as the template.
scripts/deploy.env

# Python bytecode cache (scripts/sunoapi/ — the Suno generation pipeline).
__pycache__/
*.pyc

# SQLite store for username-only accounts + per-user stats (server/db.js). The
# DB file plus its WAL/SHM sidecars are runtime state, never committed.
server/data/

# Sprite staging: per-frame SVGs emitted by scripts/gen-sprites.js. Regenerable
# from the species builders; only the packed assets/sprites/atlas.{png,json} are
# the committed runtime artifact (a clean clone boots on the atlas, no sharp).
assets/sprites/frames/

# Tile staging: per-tile SVGs emitted by scripts/gen-tiles.js. Regenerable from
# the tile builders; only the packed assets/tiles/tileset.{png,json} are the
# committed runtime artifact (a clean clone boots on the tileset, no sharp).
assets/tiles/svg/

# Audio staging: raw Suno samples + provenance from scripts/generate-{music,sfx}.py,
# and raw ElevenLabs voice clips + provenance from scripts/generate-voice.py.
# For Suno: two samples + a <key>.json (request + raw response) per asset; sample #1 is
# auto-copied to the committed assets/{music,sfx}/ target. For voice: the raw .mp3 +
# <key>.json provenance; the clip is auto-copied to assets/voice/<key>.mp3. Regenerable,
# large, and OUTSIDE Vite publicDir so raw never ships in the bundle/APK.
asset-pipeline/output/
# Rolling backups written by change-*-track.py next to the target before a swap.
assets/music/*.bak
assets/sfx/*.bak
assets/voice/*.bak

# --- Capacitor / Android ---
#
# DECISION: the native `client/android/` project IS committed (the norm for a
# real, shipping app — so signing config, generated icons/splash, and any custom
# native code are version-controlled and the release APK is reproducible). The
# project is still regenerable from the committed Capacitor config + the icon
# generator (`cd client && npx cap sync`, `node scripts/gen-android-icons.js`),
# but committing it pins the exact native state reviewers' builds came from.
#
# Capacitor's generated `client/android/.gitignore` already excludes the real
# build output (build/, .gradle/, local.properties, *.apk/*.aab, copied web
# assets). The patterns below re-assert those exclusions from the repo root and,
# critically, keep all signing material out of git.
android/app/build/
android/build/
android/.gradle/
android/local.properties
android/capacitor-cordova-android-plugins/
*.apk
*.aab

# Signing material — MUST never be committed. Losing the keystore means you can
# never ship an update to an already-installed/published app, so back it up
# OUTSIDE the repo. keystore.properties holds the passwords; it is git-ignored.
*.keystore
*.jks
keystore.properties
android/keystore.properties

# Claude Code session scratch (worktrees, locks) — never commit.
# Ignore the CONTENTS (not the dir itself) so git still descends and the
# negation below can re-include the one tracked subtree.
.claude/*
# …except the project-level subagent definitions: shared tooling that every
# contributor should get on clone, so they are tracked.
!.claude/agents/
